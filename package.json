{
  "name": "fastmd-explorer",
  "version": "1.0.2",
  "description": "Lightweight Markdown file explorer and previewer",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "bin": {
    "fastmd-explorer": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "dev": "node --watch src/cli.js",
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:exe": "pkg src/_bundle.cjs --targets node22-win-x64 --output dist/fastmd-explorer.exe",
    "build:patch": "node scripts/patch-subsystem.mjs dist/fastmd-explorer.exe",
    "build": "pnpm run build:bundle && pnpm run build:exe && pnpm run build:patch"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/mermaid/dist/mermaid.min.js",
      "node_modules/highlight.js/styles/github.css",
      "node_modules/highlight.js/styles/github-dark.css",
      "src/picker.ps1",
      "mdexplorer.config.json.sample"
    ]
  },
  "dependencies": {
    "express": "^4.22.2",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "marked-highlight": "^2.1.1",
    "mermaid": "^10.9.6",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0"
  }
}
